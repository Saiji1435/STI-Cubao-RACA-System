datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  name          String?
  password      String?
  emailVerified Boolean     @default(false)
  image         String?
  role          Role        @default(STAFF)
  sessions      Session[]
  accounts      Account[]
  logs          EventLog[]
  requests      Request[]
  racas         Raca[]      
  approvals     Approval[]  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

enum Role {
  ADMIN
  HEAD
  FACULTY
  STAFF
}

enum ItemCondition {
  GOOD
  DEFECTIVE
  REPAIR_PENDING
}

model Room {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  floor       String?
  type        String?
  description String?
  capacity    Int         @default(50) 
  items       Item[]      
  inventory   Inventory[]
  schedules   Schedule[]
  requests    Request[]
  racas       Raca[]       
}

model Request {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  status      String   @default("PENDING")

  // Adding these makes your system "Schedule-Aware"
  startDate   DateTime @default(now()) 
  endDate     DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  roomId      Int
  room        Room     @relation(fields: [roomId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Item {
  id       Int    @id @default(autoincrement())
  name     String @unique
  quantity Int    @default(0) 
  roomId   Int?   
  room     Room?  @relation(fields: [roomId], references: [id])
}

model Inventory {
  id          String        @id @default(uuid())
  itemName    String
  quantity    Int           @default(0)
  imageUrl    String?
  condition   ItemCondition @default(GOOD)
  roomId      Int
  room        Room          @relation(fields: [roomId], references: [id])
  racaRecords Raca[]
  checkouts   ItemCheckout[] 
  logs        EventLog[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Raca {
  id                String      @id @default(uuid())
  requestorId       String
  requestor         User        @relation(fields: [requestorId], references: [id])
  natureOfActivity  String
  objectives        String      @db.Text
  startDate         DateTime
  endDate           DateTime
  expectedAudience  Int?
  speaker           String?
  roomId            Int?
  room              Room?       @relation(fields: [roomId], references: [id])
  otherVenue        String?
  inventoryId       String?
  inventory         Inventory?  @relation(fields: [inventoryId], references: [id])
  status            String      @default("PENDING_HEAD_APPROVAL") 
  filePath          String?    
  eventLogs         EventLog[]
  approvals         Approval[] 
  schedule          Schedule?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Schedule {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  attendees Int      @default(1) 
  status    String   @default("PENDING") 
  roomId    Int
  room      Room     @relation(fields: [roomId], references: [id])
  racaId    String?  @unique
  raca      Raca?    @relation(fields: [racaId], references: [id])
  itemsUsed ItemCheckout[]
  createdAt DateTime @default(now())
}

model ItemCheckout {
  id          String    @id @default(uuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  scheduleId  String
  schedule    Schedule  @relation(fields: [scheduleId], references: [id])
  quantity    Int       @default(1)
}

model EventLog {
  id          String     @id @default(uuid())
  action      String 
  summary     String     @db.Text
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  racaId      String?
  raca        Raca?      @relation(fields: [racaId], references: [id])
  inventoryId String?
  inventory   Inventory? @relation(fields: [inventoryId], references: [id])
  createdAt   DateTime   @default(now())
}

model Approval {
  id           String   @id @default(uuid())
  racaId       String
  raca         Raca     @relation(fields: [racaId], references: [id], onDelete: Cascade)
  approverId   String
  approver     User     @relation(fields: [approverId], references: [id])
  roleType     Role     
  status       String   @default("APPROVED")
  signatureUrl String   
  signedAt     DateTime @default(now())
}